# Copy this file to .env for LOCAL testing only (never commit the real .env)
# In production, set these in the Vercel dashboard instead:
# Project → Settings → Environment Variables

# Required — powers the AI chat only.
ANTHROPIC_API_KEY=your-anthropic-key-here

# Optional — used by /api/weather.js. If unset, falls back to a shared
# demo key that lives on the server only (never sent to the browser), so
# weather still works without this once deployed.
WEATHER_API_KEY=your-openweathermap-key-here

# Optional — used by /api/market.js. If unset, falls back to data.gov.in's
# official public sample key automatically, so market prices still work
# without this.
MARKET_API_KEY=your-datagovin-key-here

# Google Sign-In is NOT set here — it needs a Client ID pasted into the
# GOOGLE_CLIENT_ID constant in index.html (it must be tied to your domain,
# so it can't be an env var).
